# AV Learning Prototype - Environment Configuration
# Copy this file to .env and fill in your API keys

# Speech Recognition API (optional - uses Web Speech API by default)
# For production, you may want to use a dedicated speech service
SPEECH_API_KEY=

# Text-to-Speech API (optional - uses Web Speech API by default)
TTS_API_KEY=

# Google Cloud API (for advanced features like real-time translation)
GOOGLE_CLOUD_API_KEY=

# OpenAI API (for AI-powered contextual learning suggestions)
OPENAI_API_KEY=

# Maps API (for real GPS integration in production)
MAPS_API_KEY=

# Analytics (optional)
ANALYTICS_ID=
